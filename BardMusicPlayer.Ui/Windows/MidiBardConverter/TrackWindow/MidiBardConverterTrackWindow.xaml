<Window x:Class="BardMusicPlayer.Ui.Windows.MidiBardConverter.MidiBardConverterTrackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BardMusicPlayer.Ui.Windows.MidiBardConverter"
        Title="Track Editor" Height="800" Width="1200"
        Background="#1E1E1E" TextElement.Foreground="White"
        Closing="Window_Closed">

    <Window.Resources>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="#444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="AutomationPointStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Fill" Value="#888"/>
            <Setter Property="Stroke" Value="Orange"/>
            <Setter Property="StrokeThickness" Value="10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Fill" Value="#00ADEF"/>
                    <Setter Property="Stroke" Value="#4400ADEF"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Dark ComboBox für den Editor ─────────────────────────── -->
        <ControlTemplate x:Key="DarkComboBoxToggle" TargetType="ToggleButton">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="20"/>
                    </Grid.ColumnDefinitions>
                    <ContentPresenter Grid.Column="0" Margin="6,0,0,0"
                                      VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                          Fill="Orange" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </Border>
        </ControlTemplate>

        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background"           Value="#1E1E1E"/>
            <Setter Property="Foreground"           Value="White"/>
            <Setter Property="BorderBrush"          Value="Orange"/>
            <Setter Property="BorderThickness"      Value="1"/>
            <Setter Property="Padding"              Value="4,2"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background"  Value="#2D2D2D"/>
                        <Setter Property="Foreground"  Value="White"/>
                        <Setter Property="Padding"     Value="6,3"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF8800"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#CC6600"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Name="Border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                  IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay,
                                                              RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent" BorderThickness="0"
                                                  Focusable="False"/>
                                    <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                                          Fill="Orange" VerticalAlignment="Center" HorizontalAlignment="Center"
                                          IsHitTestVisible="False"/>
                                </Grid>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide" Placement="Bottom">
                                <Border Background="#2D2D2D" BorderBrush="Orange" BorderThickness="1"
                                        MaxHeight="200" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#FFAA00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <!-- Menubar -->
            <RowDefinition Height="40"/>
            <!-- Toolbar -->
            <RowDefinition Height="30"/>
            <!-- Ruler   -->
            <RowDefinition Height="*"/>
            <!-- Editor  -->
            <RowDefinition Height="30"/>
            <!-- Footer  -->
        </Grid.RowDefinitions>

        <!-- ═══ MENUBAR ═══════════════════════════════════════════════ -->
        <Menu Grid.Row="0" Background="#444" Foreground="White">
            <MenuItem Header="Tools">
                <MenuItem Header="Autotranspose" Click="AutoTranspose_Click"/>
                <MenuItem Header="Quantize"      Click="Quantize_Click"/>
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="Undo (Ctrl+Z)" Click="Undo_Click"/>
                <MenuItem Header="Redo (Ctrl+Y)" Click="Redo_Click"/>
            </MenuItem>
        </Menu>

        <!-- ═══ TOOLBAR ═══════════════════════════════════════════════ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Background="#2D2D2D">
            <Button Content="Save" Click="SaveTrack_Click" Margin="5" Padding="15,0" Background="#3E3E3E" Foreground="White"/>
            <Separator Margin="10,5" Background="#444"/>

            <!-- Playback-Buttons -->
            <Button x:Name="PlayButton"  Content="▶" Click="PlayButton_Click"
                    Margin="3,5" Width="30" Background="#3E3E3E" Foreground="#646464"
                    FontSize="14" ToolTip="Play (Space)"/>
            <Button x:Name="PauseButton" Content="⏸" Click="PauseButton_Click"
                    Margin="3,5" Width="30" Background="#3E3E3E" Foreground="#646464"
                    FontSize="14" ToolTip="Pause (Space)"/>
            <Button x:Name="StopButton"  Content="⏹" Click="StopButton_Click"
                    Margin="3,5" Width="30" Background="#3E3E3E" Foreground="#F44336"
                    FontSize="14" ToolTip="Stop"/>

            <!-- Siren-Toggle -->
            <ToggleButton x:Name="SirenToggle" Content="🔊 Siren"
                          Margin="5,5" Padding="8,0"
                          Background="#3E3E3E" Foreground="#AAA" FontSize="11"
                          ToolTip="Audio über Siren (interner Synthesizer) statt MIDI-Output"
                          Checked="SirenToggle_Checked" Unchecked="SirenToggle_Unchecked"/>

            <!-- Zeitanzeige -->
            <TextBlock x:Name="PlaybackTimeText" Text="0:00.000"
                       VerticalAlignment="Center" Margin="8,0"
                       Foreground="#888" FontSize="11" FontFamily="Consolas"/>

            <Separator Margin="10,5" Background="#444"/>
            <TextBlock Text="Snap:" VerticalAlignment="Center" Margin="10,0,5,0" Foreground="#AAA"/>
            <ComboBox Name="SnapComboBox" Width="80" Height="25"
                      Style="{StaticResource DarkComboBox}"
                      SelectionChanged="SnapComboBox_SelectionChanged">
                <ComboBoxItem Content="1/4"  Tag="1.0"/>
                <ComboBoxItem Content="1/8"  Tag="0.5"/>
                <ComboBoxItem Content="1/16" Tag="0.25" IsSelected="True"/>
                <ComboBoxItem Content="1/32" Tag="0.125"/>
            </ComboBox>
            <TextBlock Name="CurrentToolText" Text="Tool: Select" VerticalAlignment="Center"
                       Margin="20,0" Foreground="Orange" FontWeight="Bold"/>
            <TextBlock Text="(S) Select | (D) Draw | (E) Erase | (DEL) Delete"
                       VerticalAlignment="Center" Foreground="#666" FontSize="11"/>
        </StackPanel>

        <!-- ═══ RULER ═════════════════════════════════════════════════ -->
        <Canvas Grid.Row="2" Name="RulerCanvasParent" Background="#252525"
                Margin="60,0,0,0" ClipToBounds="True"
                MouseLeftButtonDown="RulerCanvasParent_MouseLeftButtonDown"
                MouseMove="RulerCanvasParent_MouseMove"
                MouseLeftButtonUp="RulerCanvasParent_MouseLeftButtonUp"
                Cursor="Hand">
            <Canvas Name="RulerCanvas" Height="30"/>
            <!-- Playhead-Marker im Ruler -->
            <Canvas Name="PlayheadRulerCanvas" IsHitTestVisible="False" Height="30">
                <Line Name="PlayheadRulerLine"
                      X1="0" X2="0" Y1="0" Y2="30"
                      Stroke="#FF4444" StrokeThickness="2"
                      Visibility="Collapsed"/>
                <Polygon Name="PlayheadArrow"
                         Fill="#FF4444"
                         Points="0,0 -5,8 5,8"
                         Visibility="Collapsed"/>
            </Canvas>
        </Canvas>

        <!-- ═══ MAIN CONTENT ══════════════════════════════════════════ -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" MinHeight="150"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="1*" MinHeight="80"/>
            </Grid.RowDefinitions>

            <!-- ─── PIANO ROLL ──────────────────────────────────────── -->
            <Grid Grid.Row="0" KeyDown="NotesCanvas_KeyDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Canvas Grid.Column="0" Name="PianoKeysParent" Background="#252525" ClipToBounds="True">
                    <StackPanel Name="PianoKeysStack" Width="60"/>
                </Canvas>

                <ScrollViewer Grid.Column="1" Name="MainScroll"
                              HorizontalScrollBarVisibility="Visible"
                              VerticalScrollBarVisibility="Visible"
                              PreviewMouseWheel="MainScroll_PreviewMouseWheel">
                    <Grid Name="EditorGrid" Background="#121212">
                        <Canvas Name="GridCanvas"    IsHitTestVisible="False"/>
                        <Canvas Name="MarkersCanvas" IsHitTestVisible="False"/>
                        <Canvas Name="NotesCanvas" Background="Transparent" Focusable="True">
                            <Canvas.ContextMenu>
                                <ContextMenu Background="#2D2D2D" Foreground="White">
                                    <MenuItem Header="Select (S)" Click="SetTool_Click" Tag="Select"/>
                                    <MenuItem Header="Draw (D)"   Click="SetTool_Click" Tag="Draw"/>
                                    <MenuItem Header="Erase (E)"  Click="SetTool_Click" Tag="Erase"/>
                                </ContextMenu>
                            </Canvas.ContextMenu>
                            <Rectangle Name="SelectionRect"
                                       Stroke="Cyan" StrokeThickness="1"
                                       Fill="#3300FFFF"
                                       Visibility="Collapsed"
                                       IsHitTestVisible="False"/>
                        </Canvas>
                        <!-- Playhead über allem – IsHitTestVisible=False damit Noten anklickbar bleiben -->
                        <Canvas Name="PlayheadCanvas" IsHitTestVisible="False">
                            <Line Name="PlayheadLine"
                                  X1="0" X2="0" Y1="0" Y2="2560"
                                  Stroke="#FF4444" StrokeThickness="1.5"
                                  Opacity="0.85"
                                  Visibility="Collapsed"/>
                        </Canvas>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#444"/>

            <!-- ─── AUTOMATION ──────────────────────────────────────── -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#252525" BorderThickness="0,0,1,0" BorderBrush="#111">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="PROG" HorizontalAlignment="Center" FontWeight="Bold" Foreground="White" FontSize="10"/>
                        <TextBlock x:Name="AutomationValueLabel" Text="0" HorizontalAlignment="Center" Foreground="White" FontSize="9"/>
                    </StackPanel>
                </Border>

                <Popup x:Name="ValuePopup" Placement="MousePoint" AllowsTransparency="True"
                       PopupAnimation="Fade" HorizontalOffset="10" VerticalOffset="10">
                    <Border Background="#333333" CornerRadius="4" Padding="5,2"
                            BorderBrush="Orange" BorderThickness="1">
                        <TextBlock x:Name="ValuePopupText" Foreground="Orange"
                                   FontSize="11" FontWeight="Bold" Text="0"/>
                    </Border>
                </Popup>

                <ScrollViewer Grid.Column="1" Name="ControllerScroll"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled">
                    <Grid Name="AutomationContainer">
                        <Canvas Name="AutomationGridCanvas" Background="#121212" IsHitTestVisible="False"/>
                        <Canvas Name="AutomationCanvas"
                                Background="#01000000" ClipToBounds="True"
                                Focusable="True"
                                MouseLeftButtonDown="AutomationCanvas_MouseLeftButtonDown"
                                MouseMove="AutomationCanvas_MouseMove"
                                MouseLeftButtonUp="AutomationCanvas_MouseLeftButtonUp"
                                MouseRightButtonUp="AutomationCanvas_MouseRightButtonUp"
                                MouseEnter="AutomationCanvas_MouseEnter"
                                MouseLeave="AutomationCanvas_MouseLeave"
                                KeyDown="AutomationCanvas_KeyDown"
                                SizeChanged="AutomationCanvas_SizeChanged">
                            <Canvas.ContextMenu>
                                <ContextMenu x:Name="AutomationContextMenu" Background="#2D2D2D" Foreground="White">
                                    <MenuItem Header="Selection mode"   Click="AutomationCtx_SelectionMode"/>
                                    <MenuItem Header="Range mode"       Click="AutomationCtx_RangeMode"/>
                                    <Separator Background="#444"/>
                                    <MenuItem Header="Set program for range..." Click="AutomationCtx_SetProgramForRange"
                                              x:Name="AutomationCtx_SetProgramItem" IsEnabled="False"/>
                                </ContextMenu>
                            </Canvas.ContextMenu>
                            <!-- Normal selection rect (cyan) -->
                            <Rectangle Name="AutomationSelectionRect"
                                       Stroke="Cyan" StrokeThickness="1"
                                       Fill="#3300FFFF"
                                       Visibility="Collapsed"
                                       IsHitTestVisible="False"/>
                            <!-- Range selection rect (orange) -->
                            <Rectangle Name="AutomationRangeRect"
                                       Stroke="Orange" StrokeThickness="1"
                                       Fill="#33FF8800"
                                       Visibility="Collapsed"
                                       IsHitTestVisible="False"/>
                        </Canvas>

                        <!-- Range-Zeitanzeige – außerhalb des geclippten Canvas damit sie immer sichtbar ist -->
                        <Canvas Name="AutomationLabelCanvas" IsHitTestVisible="False">
                            <Border Name="AutomationRangeLabel"
                                    Background="#CC1E1E1E" BorderBrush="Orange" BorderThickness="1"
                                    CornerRadius="3" Padding="4,2"
                                    Visibility="Collapsed" IsHitTestVisible="False">
                                <TextBlock Name="AutomationRangeLabelText"
                                           Foreground="Orange" FontSize="10" FontFamily="Consolas"/>
                            </Border>
                        </Canvas>

                        <!-- Program-Input Popup -->
                        <Popup x:Name="ProgramInputPopup"
                               Placement="MousePoint" AllowsTransparency="True"
                               StaysOpen="True" HorizontalOffset="5" VerticalOffset="5">
                            <Border Background="#2D2D2D" BorderBrush="Orange" BorderThickness="1"
                                    CornerRadius="4" Padding="8">
                                <StackPanel>
                                    <TextBlock Text="Instrument für Bereich:" Foreground="#AAA" FontSize="11" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="ProgramInstrumentBox"
                                              Width="180" Height="26"
                                              Style="{StaticResource DarkComboBox}"
                                              SelectionChanged="ProgramInstrumentBox_SelectionChanged"/>
                                    <CheckBox x:Name="ProgramRestoreCheck"
                                              Content="Danach auf vorheriges Programm zurücksetzen"
                                              Foreground="#AAA" FontSize="10"
                                              IsChecked="True" Margin="0,6,0,4"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                                        <Button Content="OK" Padding="12,2" Margin="0,0,6,0"
                                                Background="#3E3E3E" Foreground="White"
                                                Click="ProgramInputBox_OK"/>
                                        <Button Content="Abbrechen" Padding="8,2"
                                                Background="#3E3E3E" Foreground="#AAA"
                                                Click="ProgramInputBox_Cancel"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ═══ FOOTER ════════════════════════════════════════════════ -->
        <StatusBar Grid.Row="4" Background="#2D2D2D">
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Zoom:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="White"/>
                    <Slider Name="ZoomSlider" Width="150" Minimum="0.01" Maximum="1.0"
                            Value="0.1" ValueChanged="ZoomSlider_ValueChanged"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
