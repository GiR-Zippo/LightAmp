<Window x:Class="BardMusicPlayer.Ui.Windows.MidiBardConverter.MidiBardConverterTrackWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Track Editor" Height="800" Width="1200"
        Background="#1E1E1E" TextElement.Foreground="White"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="#444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style x:Key="AutomationPointStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Fill" Value="#888"/>
            <!-- Normal-Color -->
            <Setter Property="Stroke" Value="Orange"/>
            <Setter Property="StrokeThickness" Value="10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Fill" Value="#00ADEF"/>
                    <!-- Hover-Color -->
                    <Setter Property="Stroke" Value="#4400ADEF"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <!-- Menubar -->
            <RowDefinition Height="40"/>
            <!-- Toolbar -->
            <RowDefinition Height="30"/>
            <!-- Ruler -->
            <RowDefinition Height="*"/>
            <!-- Editor Area -->
            <RowDefinition Height="30"/>
            <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- Menubar -->
        <Menu Grid.Row="0" Grid.ColumnSpan="2" Background="#444" Foreground="White">
            <MenuItem Header="Tools">
                <MenuItem Header="Autotranspose" Click="AutoTranspose_Click" />
                <MenuItem Header="Quantize" Click="Quantize_Click" />
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="Undo (Ctrl+Z)" Click="Undo_Click" />
                <MenuItem Header="Redo (Ctrl+Y)" Click="Redo_Click" />
            </MenuItem>
        </Menu>

        <!-- TOOLBAR -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Background="#2D2D2D">
            <Button Content="Save" Click="SaveTrack_Click" Margin="5" Padding="15,0" Background="#3E3E3E" Foreground="White"/>
            <Separator Margin="10,5" Background="#444"/>
            <TextBlock Text="Snap:" VerticalAlignment="Center" Margin="10,0,5,0" Foreground="#AAA"/>
            <ComboBox Name="SnapComboBox" Width="80" Height="25" SelectionChanged="SnapComboBox_SelectionChanged">
                <ComboBoxItem Content="1/4" Tag="1.0"/>
                <ComboBoxItem Content="1/8" Tag="0.5"/>
                <ComboBoxItem Content="1/16" Tag="0.25" IsSelected="True"/>
                <ComboBoxItem Content="1/32" Tag="0.125"/>
            </ComboBox>
            <TextBlock Name="CurrentToolText" Text="Tool: Select" VerticalAlignment="Center" Margin="20,0" Foreground="Orange" FontWeight="Bold"/>
            <TextBlock Text="(S) Select | (D) Draw | (E) Erase | (DEL) Delete" VerticalAlignment="Center" Foreground="#666" FontSize="11"/>
        </StackPanel>

        <!-- RULER -->
        <Canvas Grid.Row="2" Name="RulerCanvasParent" Background="#252525" Margin="60,0,0,0" ClipToBounds="True">
            <Canvas Name="RulerCanvas" Height="30"/>
        </Canvas>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" MinHeight="150"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="1*" MinHeight="80"/>
            </Grid.RowDefinitions>

            <!-- PIANO ROLL SECTION -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Canvas Grid.Column="0" Name="PianoKeysParent" Background="#252525" ClipToBounds="True">
                    <StackPanel Name="PianoKeysStack" Width="60" />
                </Canvas>

                <ScrollViewer Grid.Column="1" Name="MainScroll" HorizontalScrollBarVisibility="Visible" VerticalScrollBarVisibility="Visible"
                              ScrollChanged="MainScroll_ScrollChanged" PreviewMouseWheel="MainScroll_PreviewMouseWheel">
                    <Grid Name="EditorGrid" Background="#121212">
                        <Canvas Name="GridCanvas" IsHitTestVisible="False"/>
                        <Canvas Name="MarkersCanvas" IsHitTestVisible="False"/>
                        <Canvas Name="NotesCanvas" Background="Transparent">
                            <Canvas.ContextMenu>
                                <ContextMenu Background="#2D2D2D" Foreground="White">
                                    <MenuItem Header="Select (S)" Click="SetTool_Click" Tag="Select"/>
                                    <MenuItem Header="Draw (D)" Click="SetTool_Click" Tag="Draw"/>
                                    <MenuItem Header="Erase (E)" Click="SetTool_Click" Tag="Erase"/>
                                </ContextMenu>
                            </Canvas.ContextMenu>
                            <Rectangle Name="SelectionRect" Stroke="Cyan" StrokeThickness="1" Fill="#3300FFFF" Visibility="Collapsed" IsHitTestVisible="False"/>
                        </Canvas>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#444"/>

            <!-- AUTOMATION SECTION -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Linke Beschriftung -->
                <Border Grid.Column="0" Background="#252525" BorderThickness="0,0,1,0" BorderBrush="#111">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="PROG" HorizontalAlignment="Center" FontWeight="Bold" Foreground="White" FontSize="10"/>
                        <TextBlock x:Name="AutomationValueLabel" Text="0" HorizontalAlignment="Center" Foreground="White" FontSize="9"/>
                    </StackPanel>
                </Border>

                <Popup x:Name="ValuePopup" Placement="MousePoint" AllowsTransparency="True" PopupAnimation="Fade" HorizontalOffset="10" VerticalOffset="10">
                    <Border Background="#333333" CornerRadius="4" Padding="5,2" BorderBrush="Orange" BorderThickness="1">
                        <TextBlock x:Name="ValuePopupText" Foreground="Orange" FontSize="11" FontWeight="Bold" Text="0"/>
                    </Border>
                </Popup>

                <!-- Die Zeichenfläche -->
                <ScrollViewer Grid.Column="1" 
                  Name="ControllerScroll" 
                  HorizontalScrollBarVisibility="Hidden" 
                  VerticalScrollBarVisibility="Disabled">
                    <Grid Name="AutomationContainer">
                        <Canvas Name="AutomationGridCanvas" Background="#121212" IsHitTestVisible="False"/>
                        <Canvas Name="AutomationCanvas"
                            Background="Transparent" 
                            ClipToBounds="True"
                            MouseLeftButtonDown="AutomationCanvas_MouseLeftButtonDown"
                            MouseMove="AutomationCanvas_MouseMove" 
                            MouseLeftButtonUp="AutomationCanvas_MouseLeftButtonUp"
                            SizeChanged="AutomationCanvas_SizeChanged">
                        </Canvas>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- FOOTER -->
        <StatusBar Grid.Row="4" Background="#2D2D2D">
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Zoom:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="White"/>
                    <Slider Name="ZoomSlider" Width="150" Minimum="0.01" Maximum="1.0" Value="0.1" ValueChanged="ZoomSlider_ValueChanged"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>