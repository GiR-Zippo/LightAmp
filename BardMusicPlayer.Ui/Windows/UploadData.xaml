<Window x:Class="BardMusicPlayer.Ui.Windows.UploadData"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BardMusicPlayer.Ui.Windows"
        mc:Ignorable="d"
        WindowStyle="ToolWindow"
        Title="UploadData" Height="200" Width="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Label   Grid.Row="0" Grid.Column="1" Content="RegEx" Visibility="Hidden"/>
        <TextBox Grid.Row="0" Grid.Column="2" x:Name="regex_txt" Visibility="Hidden"/>

        <Label   Grid.Row="1" Grid.Column="1" Content="Artist"/>
        <TextBox Grid.Row="1" Grid.Column="2" x:Name="artist_txt" />

        <Label   Grid.Row="2" Grid.Column="1" Content="Title"/>
        <TextBox Grid.Row="2" Grid.Column="2" x:Name="title_txt" />

        <Label   Grid.Row="3" Grid.Column="1" Content="Source"/>
        <TextBox Grid.Row="3" Grid.Column="2" x:Name="source_txt" />

        <Label   Grid.Row="4" Grid.Column="1" Content="Source Url"/>
        <TextBox Grid.Row="4" Grid.Column="2" x:Name="source_url_txt" />

        <Button Grid.Row="6" Grid.Column="1" Content="Okay" Click="Okay_Click"/>
        <Button Grid.Row="6" Grid.Column="2" Width="100" HorizontalAlignment="Right" Content="Cancel" Click="Cancel_Click"/>
    </Grid>
</Window>
